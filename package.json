{
  "name": "com.mkoelle",
  "version": "1.0.0",
  "description": "Base project for mkoelle.com",
  "main": "index.js",
  "scripts": {
    "start": "npx @11ty/eleventy --serve",
    "build": "npx @11ty/eleventy",
    "clean": "rimraf _site",
    "clean-all": "rimraf _site node_modules package-lock.json",
    "deps-check": "ncu",
    "deps-fix": "ncu -u",
    "cspell-source": "cspell src/**/* --show-suggestions --unique",
    "cspell-changed": "git diff --name-only | cspell --file-list stdin --show-suggestions --unique"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkoelle/com.mkoelle.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mkoelle/com.mkoelle/issues"
  },
  "homepage": "https://github.com/mkoelle/com.mkoelle#readme",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@11ty/eleventy-navigation": "^0.3.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@11ty/eleventy-plugin-vite": "^4.0.0",
    "autoprefixer": "^10.4.19",
    "cspell": "^8.12.1",
    "npm-check-updates": "^16.14.20",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.40",
    "prismjs": "^1.29.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.7"
  },
  "dependencies": {
    "alpinejs": "^3.14.1"
  }
}