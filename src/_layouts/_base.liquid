<!DOCTYPE html>
<html lang="en" x-data="{ darkMode: localStorage.getItem('dark') === 'true'} "
  x-init="$watch('darkMode', val => localStorage.setItem('dark', val))" x-bind:class="{ 'dark': darkMode }">

<head>
  <title>{{site.title}}{% if title %} - {{title}}{% endif %}
  </title>
  <meta charset="UTF-8" />
  <meta name="description" content="{{ description | default: site.description }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ site.baseURL }}{{ page.url }}" />
  <meta property="og:title" content="{{ title | default: site.title }}" />
  <meta property="og:description" content="{{ description | default: site.description }}" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="{{ title | default: site.title }}" />
  <meta name="twitter:description" content="{{ description | default: site.description }}" />
  <link rel="canonical" href="{{ site.baseURL }}{{ page.url }}" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, viewport-fit=cover" />
  {% block head %}{% endblock %}
  <meta name="generator" content="{{ eleventy.generator }}">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "{{ site.author }}",
    "url": "{{ site.baseURL }}",
    "sameAs": [{% for s in site.social %}"{{ s.url }}"{% unless forloop.last %},{% endunless %}{% endfor %}]
  }
  </script>
</head>

<body
  class="antialiased bg-cover bg-no-repeat bg-fixed bg-center dark:bg-black dark:bg-gradient-to-br dark:from-emerald-900 dark:text-white bg-green-400 text-black bg-gradient-to-tl from-white flex flex-col min-h-screen ">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black">Skip to main content</a>
  {% render "partials/_navigation", collections: collections, page: page %}
    {% block content %}
    {{ content }}
    {% endblock %}
  {% render "partials/footer", socials: site.social %}
  <script type="module" src="/assets/js/main.js"></script>
  <div @keyup.space.window="$refs.wow.play()"></div>
  <audio x-ref="wow">
    <source src="/assets/audio/owen-wilson-wow-q.mp3" type="audio/mpeg" />
  </audio>
</body>
</html>