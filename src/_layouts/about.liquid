---
layout: _base
---
<main id="main-content" class="flex-grow py-8 px-4">
  <div class="max-w-4xl mx-auto">
    <article class="
      bg-white/90 dark:bg-black/60
      backdrop-blur-sm
      rounded-2xl
      shadow-lg
      px-8 py-10
      md:px-14 md:py-12
      prose prose-stone
      dark:prose-invert
      prose-headings:font-semibold
      prose-h1:text-3xl prose-h1:border-b prose-h1:border-stone-200 prose-h1:pb-4 dark:prose-h1:border-stone-700
      prose-h2:text-xl prose-h2:text-emerald-700 dark:prose-h2:text-emerald-400 prose-h2:uppercase prose-h2:tracking-wider prose-h2:mt-10 prose-h2:mb-3
      prose-h3:text-base prose-h3:font-semibold prose-h3:mb-0
      prose-h4:text-sm prose-h4:font-semibold prose-h4:text-stone-600 dark:prose-h4:text-stone-400 prose-h4:uppercase prose-h4:tracking-wide prose-h4:mt-6 prose-h4:mb-1
      prose-strong:font-semibold
      prose-em:text-stone-500 dark:prose-em:text-stone-400 prose-em:not-italic prose-em:text-sm
      prose-hr:border-stone-200 dark:prose-hr:border-stone-700 prose-hr:my-8
      prose-ul:my-2 prose-li:my-0.5
      prose-p:leading-relaxed
      max-w-none
